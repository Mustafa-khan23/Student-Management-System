<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />

    <title>Student | <%= usr.name %></title>
  </head>
  <body>
    <%- include("partials/navbar") %>
    <div class="card mx-auto" style="width: 18rem">
      <% let redImage; %> 
      <% let Img1 = "/images/male.png"; %> 
      <% let Img2 ="/images/female.png"; %>

      <% if(usr.gender == "Female") { %>
        <% redImage = Img2 %>
        <% } else { %>
            <% redImage = Img1; %>
        <% } %>

        <% let pronouns; %>
        <% if(usr.gender == "Male") { %>
        <% pronouns = "he" %>
        <% } else { %>
            <% pronouns = "she" %>
        <% } %>    
      <img src="<%= redImage %>" class="card-img-top" alt="pfp" />
      <div class="card-body" >
        <h5 class="card-title"><%= usr.name %></h5>
        <p class="card-text">
          <%= usr.name %>&nbsp;<%= pronouns %>&nbsp;is from <%= usr.course %> Department with a percentage of <%= usr.marks %>% <br>
          <h6>City: <%= usr.city %></h6>
          <a href="#">+91&nbsp;<%= usr.phone %></a>
          <h6>Email: <%= usr.email %></h6>
        </p>
        <a href="#" class="btn btn-primary">Contact</a>
      </div>
    </div>

    <%- include("partials/footer") %>
  </body>
</html>
