<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Student | <%= usr.name %></title>
  </head>
  <body>
    <%- include("partials/navbar") %>

    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
          <% let redImage = usr.gender === "Male" ? "/images/male.png" :
          "/images/female.png"; %> <% let pronoun = usr.gender === "Male" ? "he"
          : "she"; %>

          <div class="card student-detail-card">
            <img
              src="<%= redImage %>"
              class="card-img-top"
              alt="Student profile"
            />
            <div class="card-body">
              <h2 class="card-title"><%= usr.name %></h2>
              <p class="card-text">
                <%= usr.name %> is from the <%= usr.course %> department and
                scored <%= usr.marks %>% marks.
              </p>
              <ul class="list-group list-group-flush detail-list">
                <li class="list-group-item">
                  <strong>Age:</strong> <%= usr.age %>
                </li>
                <li class="list-group-item">
                  <strong>City:</strong> <%= usr.city %>
                </li>
                <li class="list-group-item">
                  <strong>Email:</strong> <%= usr.email %>
                </li>
                <li class="list-group-item">
                  <strong>Phone:</strong> +91 <%= usr.phone %>
                </li>
              </ul>
              <a href="/students" class="btn btn-primary mt-3"
                >Back to students</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include("partials/footer") %>
  </body>
</html>
